rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function hasVerifiedEmail() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email is string;
    }

    function isOwner() {
      return hasVerifiedEmail()
        && request.auth.token.email == "jareerink@gmail.com";
    }

    function isApprovedEditor() {
      return isOwner()
        || (
          hasVerifiedEmail()
          && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
        );
    }

    match /admins/{email} {
      // Allow unauthenticated get so login page can check if email is authorized
      allow get: if true;
      allow list: if isOwner();
      allow create, update, delete: if isOwner();
    }

    match /letters/{letterId} {
      allow read: if true;
      allow write: if isApprovedEditor();
    }

    match /siteContent/{documentId} {
      allow read: if true;
      allow write: if isApprovedEditor();
    }
  }
}

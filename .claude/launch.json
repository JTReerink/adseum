{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "public", "--no-clipboard"],
      "port": 3999,
      "autoPort": true
    },
    {
      "name": "ADseum",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "public", "-p", "3000"],
      "port": 3000
    },
    {
      "name": "Firebase Hosting",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["serve", "--only", "hosting"],
      "port": 5000
    },
    {
      "name": "Firebase Emulators (Hosting + Firestore)",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--only", "hosting,firestore"],
      "port": 5000
    }
  ]
}
